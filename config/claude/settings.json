{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "EDITOR": "hx",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./secrets/**)"]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -S /tmp/cmux.sock ]; then cmux notify --title 'Claude Code' --body '入力待ち'; else osascript -e 'display notification \"入力待ち\" with title \"Claude Code\"'; fi"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -S /tmp/cmux.sock ]; then cmux notify --title 'Claude Code' --body '許可が必要です'; else osascript -e 'display notification \"許可が必要です\" with title \"Claude Code\"'; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -S /tmp/cmux.sock ]; then cmux notify --title 'Claude Code' --body '応答完了'; else osascript -e 'display notification \"応答完了\" with title \"Claude Code\"'; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "language": "japanese",
  "effortLevel": "high",
  "voiceEnabled": true
}
